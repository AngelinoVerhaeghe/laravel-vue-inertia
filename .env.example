APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_PORT=80
VITE_PORT=5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Sail / Docker (see Makefile): use ./vendor/bin/sail shell — WWWUSER/WWWGROUP default from your host user
# WWWUSER=1000
# WWWGROUP=1000

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# When using MySQL only in Docker and PHP on the host, use 127.0.0.1 and FORWARD_DB_PORT below.
# FORWARD_DB_PORT=3306

# Mailpit (Sail): web UI and SMTP port mapping — see `mailpit` service in compose.yaml
# FORWARD_MAILPIT_PORT=8025
# FORWARD_MAILPIT_SMTP_PORT=1025
# Example inside Sail containers: MAIL_MAILER=smtp MAIL_HOST=mailpit MAIL_PORT=1025 MAIL_USERNAME=null MAIL_PASSWORD=null MAIL_ENCRYPTION=null

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Newsletter: confirmation link expiry (double opt-in), in days
# NEWSLETTER_CONFIRMATION_TTL_DAYS=7

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local mail: with Sail + Mailpit, use SMTP to the mailpit service (see compose.yaml) and open http://localhost:8025
# Without this, mail goes to the log driver only and nothing appears in Mailpit.
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
